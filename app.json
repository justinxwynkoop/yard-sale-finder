{
  "expo": {
    "name": "Local Hauls",
    "slug": "yard-sale-finder",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "yardsalefinder",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFEDD5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jwynkoop.yardsalefinder",
      "buildNumber": "1",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We use your location to show nearby yard sales and help you pin your own sale.",
        "NSLocationAlwaysUsageDescription": "We use your location to show nearby yard sales.",
        "NSPhotoLibraryUsageDescription": "Upload photos of your sale items.",
        "NSCameraUsageDescription": "Take photos of your sale items.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FFEDD5"
      },
      "package": "com.jwynkoop.yardsalefinder",
      "versionCode": 1,
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyA7o8V5v2nDkJsu2q3K_2jDZwKg-WZG6E8"
        }
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-location",
      "expo-image-picker",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Local Hauls to access your camera."
        }
      ],
      "expo-web-browser",
      "@react-native-community/datetimepicker",
      "expo-apple-authentication",
      "@sentry/react-native",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FFEDD5",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "21cc3271-4b50-4f32-a4e4-6823f78ec3e7"
      }
    },
    "updates": {
      "url": "https://u.expo.dev/21cc3271-4b50-4f32-a4e4-6823f78ec3e7",
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 3000
    },
    "owner": "jasonwynkoop1"
  }
}
