# Local Metro env. Copy to `.env` and fill in.
#
# Point these at the STAGING Supabase project, never prod — local dev and
# all `db:*` work should hit the disposable staging DB. See docs/PIPELINE.md.
# The anon (publishable) key is safe to commit/ship; RLS protects the data.
EXPO_PUBLIC_SUPABASE_URL=https://<staging-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<staging anon/publishable key>
EXPO_PUBLIC_ENV=development
